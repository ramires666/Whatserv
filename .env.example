# Copy to .env and replace every CHANGE_ME value before starting.
POSTGRES_DB=whatserv
POSTGRES_USER=whatserv
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DATABASE_URL=postgresql+asyncpg://whatserv:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/whatserv

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_LONG_ADMIN_PASSWORD
INTERNAL_API_TOKEN=CHANGE_ME_RANDOM_INTERNAL_TOKEN
# Independent pepper for capability-token HMACs.
ACCESS_TOKEN_PEPPER=CHANGE_ME_RANDOM_TOKEN_PEPPER
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_FERNET_KEY
QR_FERNET_KEY=CHANGE_ME_SECOND_FERNET_KEY
CREDENTIAL_FERNET_KEY=CHANGE_ME_THIRD_FERNET_KEY
PUBLIC_BASE_URL=https://messages.example.com
# Keep 127.0.0.1 when the reverse proxy is on this host. If it runs on another
# LAN machine, set the server's reachable LAN address, for example 192.168.1.66.
BACKEND_BIND_ADDRESS=127.0.0.1
ALLOW_INSECURE_HTTP=false
CAPABILITY_TTL_HOURS=720
QR_TTL_SECONDS=120

# WhatsApp gateway. This integration is unofficial and account suspension is possible.
BACKEND_INTERNAL_URL=http://backend:8000
WA_SESSION_DIR=/data/sessions
WA_RECONCILE_INTERVAL_MS=15000
WA_HEALTH_PORT=3000
LOG_LEVEL=info
